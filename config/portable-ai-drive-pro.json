{
  "app": {
    "name": "Portable AI Drive PRO",
    "version": "0.6.0-week6",
    "environment": "development"
  },
  "api": {
    "host": "127.0.0.1",
    "port": 8080
  },
  "logging": {
    "level": "INFO",
    "directory": "data/logs",
    "filename": "portable-ai-drive-pro.log",
    "to_stdout": true
  },
  "runtime": {
    "provider": "local_openai",
    "fallback_provider": "placeholder",
    "allow_fallback_to_placeholder": true,
    "default_model": "local-general",
    "default_embedding_model": "local-embedding",
    "startup_timeout_seconds": 5,
    "models": [
      {
        "public_name": "local-general",
        "provider_model_id": "llama3.2-general",
        "role": "general",
        "enabled": true,
        "metadata": {
          "description": "Primary local general assistant model",
          "stage": "week5-real-inference"
        }
      },
      {
        "public_name": "local-coder",
        "provider_model_id": "qwen2.5-coder",
        "role": "coder",
        "enabled": false,
        "metadata": {
          "description": "Reserved for coding-focused flow",
          "stage": "planned"
        }
      },
      {
        "public_name": "local-embedding",
        "provider_model_id": "nomic-embed-text",
        "role": "embedding",
        "enabled": true,
        "metadata": {
          "description": "Embedding model for upcoming RAG indexing",
          "stage": "week6-embeddings"
        }
      }
    ],
    "local_openai": {
      "base_url": "http://127.0.0.1:8081",
      "timeout_seconds": 5,
      "health_path": "/health",
      "models_path": "/v1/models",
      "chat_completions_path": "/v1/chat/completions",
      "embeddings_path": "/v1/embeddings"
    }
  },
  "operating_mode": {
    "offline_default": true
  },
  "feature_flags": {
    "openai_compatible_api": true,
    "tool_execution": false,
    "memory": false,
    "research": false
  },
  "placeholders": {
    "policy_rules": {
      "mode": "default-deny"
    },
    "tool_permissions": {},
    "memory_settings": {},
    "research_settings": {
      "enabled": false
    }
  }
}
