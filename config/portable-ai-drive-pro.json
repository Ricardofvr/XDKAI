{
  "app": {
    "name": "Portable AI Drive PRO",
    "version": "0.12.0-week12",
    "environment": "development"
  },
  "api": {
    "host": "127.0.0.1",
    "port": 8080
  },
  "logging": {
    "level": "INFO",
    "directory": "data/logs",
    "filename": "portable-ai-drive-pro.log",
    "to_stdout": true
  },
  "runtime": {
    "provider": "local_openai",
    "fallback_provider": "placeholder",
    "allow_fallback_to_placeholder": true,
    "default_model": "local-general",
    "default_embedding_model": "local-embedding",
    "startup_timeout_seconds": 5,
    "models": [
      {
        "public_name": "local-general",
        "provider_model_id": "qwen2.5-32b-general",
        "role": "general",
        "enabled": true,
        "metadata": {
          "description": "Primary local Qwen2.5 32B general assistant model",
          "stage": "week7-qwen32b"
        }
      },
      {
        "public_name": "local-coder",
        "provider_model_id": "qwen2.5-32b-coder",
        "role": "coder",
        "enabled": true,
        "metadata": {
          "description": "Qwen2.5 32B coding-focused model",
          "stage": "week7-qwen32b"
        }
      },
      {
        "public_name": "local-embedding",
        "provider_model_id": "nomic-embed-text",
        "role": "embedding",
        "enabled": true,
        "metadata": {
          "description": "Embedding model for upcoming RAG indexing",
          "stage": "week6-embeddings"
        }
      }
    ],
    "local_openai": {
      "base_url": "http://127.0.0.1:8081",
      "timeout_seconds": 5,
      "health_path": "/health",
      "models_path": "/v1/models",
      "chat_completions_path": "/v1/chat/completions",
      "embeddings_path": "/v1/embeddings"
    }
  },
  "operating_mode": {
    "offline_default": true
  },
  "feature_flags": {
    "openai_compatible_api": true,
    "tool_execution": false,
    "memory": false,
    "research": false
  },
  "chat": {
    "include_session_metadata": true,
    "debug_session": true,
    "session": {
      "directory": "data/sessions",
      "persist_to_disk": true
    },
    "history": {
      "max_turns": 8,
      "max_characters": 7000,
      "retain_system_prompt": true
    },
    "system_prompt": {
      "text": "You are Portable AI Drive PRO, a private local assistant. Use retrieved local context when relevant, avoid unsupported claims, and be concise."
    },
    "grounding": {
      "include_summary": true,
      "include_debug_details": false
    },
    "summarisation": {
      "enabled": true,
      "trigger_turn_count": 16,
      "trigger_character_count": 12000
    }
  },
  "rag": {
    "enabled": true,
    "default_embedding_model": "local-embedding",
    "chunking": {
      "chunk_size": 1000,
      "chunk_overlap": 200
    },
    "index": {
      "directory": "data/index",
      "vectors_db_filename": "vectors.db",
      "documents_filename": "documents.json",
      "metadata_filename": "metadata.json"
    },
    "retrieval": {
      "top_k": 3,
      "similarity_metric": "cosine",
      "min_similarity": -1.0
    },
    "chat": {
      "enabled": true,
      "retrieval_fetch_k": 8,
      "max_context_chunks": 3,
      "max_context_characters": 4200,
      "max_chunks_per_document": 2,
      "deduplicate_results": true,
      "near_duplicate_threshold": 0.92,
      "min_similarity": 0.1,
      "context_prefix": "You have access to the following local context. Use it when relevant and cite source metadata in your reasoning.",
      "include_source_metadata": true,
      "debug_retrieval": false
    }
  },
  "placeholders": {
    "policy_rules": {
      "mode": "default-deny"
    },
    "tool_permissions": {},
    "memory_settings": {},
    "research_settings": {
      "enabled": false
    }
  }
}
